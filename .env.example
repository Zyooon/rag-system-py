# RAG 시스템 환경 설정

# 애플리케이션 기본 설정
APP_NAME=RAG System API
APP_VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Ollama LLM 설정
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_EMBEDDING_MODEL=bge-m3

# Redis 설정
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_RAG_KEY_PREFIX=rag:documents
REDIS_EMBEDDING_KEY_PREFIX=rag:embeddings

# 벡터 저장소 설정
VECTOR_STORE_TYPE=chroma
CHROMA_PERSIST_DIRECTORY=./chroma_db
CHROMA_COLLECTION_NAME=rag_collection

# 검색 설정
SEARCH_THRESHOLD=0.3
SEARCH_MAX_RESULTS=5
SEARCH_TOP_K=10

# 문서 처리 설정 - 정밀 검색을 위한 작은 청크 크기
DOCUMENTS_FOLDER=./documents
CHUNK_SIZE=150  # 정밀 검색: 300 → 150으로 감소
CHUNK_OVERLAP=20  # 중복 감소: 50 → 20으로 감소
MIN_CHUNK_SIZE_CHARS=20  # 최소 크기 감소: 50 → 20으로 감소
LONG_DOCUMENT_THRESHOLD=800  # 긴 문서 기준: 800 → 800으로 유지
MAX_FILE_SIZE_MB=50

# 텍스트 분할 상세 설정
PRECISE_CHUNK_SIZE=100
PRECISE_MIN_CHUNK_SIZE_CHARS=30
PRECISE_MAX_NUM_CHUNKS=800
SPEED_CHUNK_SIZE=400
SPEED_MIN_CHUNK_SIZE_CHARS=100

# 파서 우선순위 설정
HIERARCHICAL_PARSER_PRIORITY=1
MARKDOWN_PARSER_PRIORITY=2
SIMPLE_LINE_PARSER_PRIORITY=3

# 시맨틱 청킹 설정
SEMANTIC_CHUNK_SIZE=500
SEMANTIC_CHUNK_OVERLAP=50
SEMANTIC_SIMILARITY_THRESHOLD=0.3
ENABLE_SEMANTIC_CHUNKING=true

# 리랭킹 설정
ENABLE_RERANKING=true
RERANK_TOP_K=5
RERANK_THRESHOLD=0.5
CROSS_ENCODER_MODEL=jhgan/ko-sroberta-multitask

# 임베딩 병렬 처리 설정
EMBEDDING_BATCH_SIZE=10
EMBEDDING_MAX_CONCURRENT=5
ENABLE_PARALLEL_EMBEDDING=true

# 지원되는 파일 형식
SUPPORTED_EXTENSIONS=.txt,.md,.pdf,.docx

# 로깅 설정
LOG_LEVEL=INFO
LOG_FILE=./logs/rag_system.log

# Spring AI 호환성 설정
SPRING_AI_COMPATIBILITY_MODE=true
